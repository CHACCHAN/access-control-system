{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "store:allow-load",
    "store:allow-get-store",
    "store:allow-get",
    "store:allow-set",
    "store:allow-save",
    {
      "identifier": "http:default",
      "allow": [{ "url": "https://*.chibatech.ac.jp/*" }]
    }
  ]
}
