{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "access-control-system",
  "version": "0.2.31",
  "identifier": "ac.jp.chibatech.access-control-system",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "access-control-system",
        "width": 800,
        "height": 600,
        "fullscreen": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "deb"
    ],
    "resources": [
      "resources/models/buffalo_l/det_10g.onnx",
      "resources/models/buffalo_l/2d106det.onnx",
      "resources/models/buffalo_l/w600k_r50.onnx",
      "resources/models/gesture/palm_detection_mediapipe_2023feb.onnx",
      "resources/models/gesture/handpose_estimation_mediapipe_2023feb.onnx",
      "resources/onnxruntime/libonnxruntime.so"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}